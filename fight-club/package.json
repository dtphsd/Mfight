{
  "name": "fight-club",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:public": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "online:server": "node ./scripts/run-online-duel-server.mjs",
    "online:server:lan": "node ./scripts/run-online-duel-server.mjs --profile=lan",
    "online:server:public": "node ./scripts/run-online-duel-server.mjs --profile=public",
    "online:server:proxy": "node ./scripts/run-online-duel-server.mjs --profile=proxy",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:validate": "node scripts/validate-content.mjs",
    "generate:module": "node scripts/generate-module.mjs",
    "specialist:entry": "node scripts/generate-specialist-entry.mjs",
    "balance:matrix": "node scripts/run-build-matrix.cjs",
    "combat:audit-zones": "node scripts/run-combat-zone-audit.cjs",
    "combat:audit-skills": "node scripts/run-skill-usage-audit.cjs",
    "combat:audit-intents": "node scripts/run-intent-usage-audit.cjs",
    "baza:parse": "node scripts/parse-bazakbk-pages.mjs",
    "baza:generate-items": "node scripts/generate-bazakbk-starter-items.mjs"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.21.0",
    "globals": "^15.15.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.24.1",
    "vite": "^6.2.0",
    "vitepress": "^1.6.4",
    "vitest": "^3.0.8"
  }
